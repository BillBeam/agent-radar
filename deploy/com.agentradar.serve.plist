<?xml version="1.0" encoding="UTF-8"?>
<!-- TEMPLATE — `scripts/install-launchd.sh` replaces __REPO__ and installs to
     ~/Library/LaunchAgents (never committed). KeepAlive = restart if it dies; runs at load. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.agentradar.serve</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__REPO__/scripts/run-serve.sh</string>
  </array>
  <key>WorkingDirectory</key><string>__REPO__</string>
  <key>KeepAlive</key><true/>
  <key>RunAtLoad</key><true/>
  <key>ThrottleInterval</key><integer>30</integer>
  <key>StandardOutPath</key><string>__REPO__/data/state/launchd-serve.log</string>
  <key>StandardErrorPath</key><string>__REPO__/data/state/launchd-serve.log</string>
</dict>
</plist>
